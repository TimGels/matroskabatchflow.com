---
const features = [
  {
    title: "Batch Editing",
    description:
      "Modify container properties like track names, languages, flags, and more across multiple files simultaneously.",
    icon: "layers",
  },
  {
    title: "Drag-and-Drop",
    description:
      "Add files or entire folders by dragging them into the application. Quick and effortless.",
    icon: "upload",
  },
  {
    title: "Flexible Validation",
    description:
      "Three validation modes: Strict, Lenient, and Custom. Custom gives you full control over how each validation check behaves.",
    icon: "shield-check",
  },
  {
    title: "Track Availability",
    description:
      "Visual indicators showing track coverage across all files in your batch at a glance.",
    icon: "bar-chart",
  },
  {
    title: "Theme Support",
    description:
      "Choose between Light, Dark, or System theme. System automatically follows your OS preference.",
    icon: "palette",
  },
];

const icons: Record<string, string> = {
  layers:
    '<path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path>',
  upload:
    '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line>',
  "shield-check":
    '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline>',
  "bar-chart":
    '<line x1="12" y1="20" x2="12" y2="10"></line><line x1="18" y1="20" x2="18" y2="4"></line><line x1="6" y1="20" x2="6" y2="16"></line>',
  code: '<polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline>',
  globe:
    '<circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>',
  palette:
    '<circle cx="13.5" cy="6.5" r="1.5"></circle><circle cx="17.5" cy="10.5" r="1.5"></circle><circle cx="8.5" cy="7.5" r="1.5"></circle><circle cx="6.5" cy="12" r="1.5"></circle><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path>',
};
---

<section
  id="features"
  class="relative py-20 sm:py-28 -mt-12 transition-colors">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2
        class="text-3xl sm:text-4xl font-bold text-surface-900 dark:text-white mb-4">
        Features
      </h2>
      <p
        class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto">
        Everything you need to batch edit your Matroska files, wrapped in a
        modern and intuitive interface.
      </p>
    </div>
    <div class="flex flex-wrap justify-center gap-6 lg:gap-8 [&>*]:w-full [&>*]:md:w-[calc(50%-0.75rem)] [&>*]:lg:w-[calc(33.333%-1.375rem)]">
      {
        features.map(({ title, description, icon }) => (
          <div class="group p-6 rounded-2xl bg-white dark:bg-surface-800/50 border border-surface-200 dark:border-surface-700/50 hover:border-primary-400 dark:hover:border-primary-700 shadow-sm hover:shadow-lg hover:shadow-primary-500/10 transition-all duration-200">
            <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4 group-hover:bg-primary-200 dark:group-hover:bg-primary-900/50 transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6 text-primary-600 dark:text-primary-400"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round">
                <Fragment set:html={icons[icon]} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-surface-900 dark:text-white mb-2">
              {title}
            </h3>
            <p class="text-surface-600 dark:text-surface-400 leading-relaxed">
              {description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
