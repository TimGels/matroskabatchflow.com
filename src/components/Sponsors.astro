---

---

<section id="sponsors" class="py-20 sm:py-24 transition-colors">
  <div class="container mx-auto px-4 text-center">
    <h2
      class="text-3xl sm:text-4xl font-bold text-surface-900 dark:text-white mb-4">
      Support the Project
    </h2>
    <p
      class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto mb-10">
      Matroska Batch Flow is free and open-source software. If you find it
      useful, the best way to support the project is by donating to help fund
      its continued development.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://github.com/sponsors/TimGels"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2.5 px-6 py-3.5 rounded-xl bg-[#bf167e] hover:bg-[#a3126b] text-white font-semibold shadow-lg shadow-[#bf167e]/25 hover:shadow-[#bf167e]/40 transition-all duration-200">
        <!-- GitHub Sponsors heart -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="currentColor">
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
        Sponsor on GitHub
      </a>
      <a
        href="https://buymeacoffee.com/timgels"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2.5 px-6 py-3.5 rounded-xl bg-[#ffdd00] hover:bg-[#e6c800] text-[#000000] font-semibold shadow-lg shadow-[#ffdd00]/25 hover:shadow-[#ffdd00]/40 transition-all duration-200">
        <!-- Coffee cup -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round">
          <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
          <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
          <line x1="6" y1="1" x2="6" y2="4"></line>
          <line x1="10" y1="1" x2="10" y2="4"></line>
          <line x1="14" y1="1" x2="14" y2="4"></line>
        </svg>
        Buy Me a Coffee
      </a>
    </div>
  </div>
</section>
