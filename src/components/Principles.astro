---
const reasons = [
  {
    title: "Open Source",
    description:
      "Matroska Batch Flow is Free Software, licensed under the GNU General Public License v3.0. The full source code is available on GitHub.",
    icon: "code",
  },
  {
    title: "No Fees",
    description:
      "No trials, no subscriptions, no premium tiers. Every feature is available to every user, no hidden costs.",
    icon: "dollar-sign",
  },
  {
    title: "Privacy First",
    description: "No tracking, no analytics, no data leaves your machine.",
    icon: "lock",
  },
];

const icons: Record<string, string> = {
  code: '<polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline>',
  "dollar-sign":
    '<line x1="12" x2="12" y1="2" y2="22"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path><line x1="3" y1="21" x2="21" y2="3" stroke-width="2"></line>',
  workflow:
    '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-workflow-icon lucide-workflow"><rect width="8" height="8" x="3" y="3" rx="2"/><path d="M7 11v4a2 2 0 0 0 2 2h4"/><rect width="8" height="8" x="13" y="13" rx="2"/></svg>',
  wrench:
    '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>',
  lock: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>',
  flag: '<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line>',
};
---

<section id="principles" class="py-20 sm:py-28 transition-colors">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2
        class="text-3xl sm:text-4xl font-bold text-surface-900 dark:text-white mb-4">
        Built on Principles
      </h2>
      <p
        class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto">
        Honest software. Open source, no strings attached.
      </p>
    </div>
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 auto-rows-[1fr]">
      {
        reasons.map(({ title, description, icon }) => (
          <div class="group p-6 rounded-2xl bg-white dark:bg-surface-800/50 border border-surface-200 dark:border-surface-700/50 hover:border-primary-400 dark:hover:border-primary-700 shadow-sm hover:shadow-lg hover:shadow-primary-500/10 transition-all duration-200 flex flex-col">
            <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4 group-hover:bg-primary-200 dark:group-hover:bg-primary-900/50 transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6 text-primary-600 dark:text-primary-400"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round">
                <Fragment set:html={icons[icon]} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-surface-900 dark:text-white mb-2">
              {title}
            </h3>
            <p class="text-surface-600 dark:text-surface-400 leading-relaxed">
              {description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
