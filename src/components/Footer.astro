        class="text-sm text-surface-700 dark:text-surface-300 text-center md:text-left flex flex-col gap-0.5">
        <span>&copy; {currentYear} Tim Gels</span>
        <span
          >Site content licensed under
          <a
            href="https://creativecommons.org/licenses/by-nc-nd/4.0/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary-700 dark:text-primary-400 underline hover:no-underline transition-colors"
            >CC BY-NC-ND 4.0</a
          ></span
        >
      </span>
      <a
        href="https://github.com/TimGels/Matroska-Batch-Flow"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm text-surface-700 dark:text-surface-300 hover:text-primary-700 dark:hover:text-primary-400 hover:underline transition-colors">
